# =============================================================================
# VOID Backend — Variables de Entorno
# =============================================================================
# INSTRUCCIONES:
#   1. Copia este archivo como .env en la misma carpeta:
#      cp .env.example .env
#   2. Rellena cada valor con tus credenciales reales.
#   3. NUNCA subas el .env al repositorio. Ya está en .gitignore.
# =============================================================================

# --- SUPABASE (Base de Datos) ---
# Obtén estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
#
# ⚠️  IMPORTANTE — Tipo de clave según el entorno:
#   - Backend (servidor):  usa la clave "service_role" (bypasea RLS, solo en servidor)
#   - Cliente móvil:       usa la clave "anon" (respeta RLS, segura para el cliente)
#   - NUNCA uses service_role en el cliente móvil.
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_KEY=tu-clave-service-role-aqui

# --- GOOGLE GEMINI (LLM / Embeddings) ---
# Obtén tu clave en: https://aistudio.google.com/apikey
GOOGLE_API_KEY=tu-google-api-key-aqui

# --- DEEPGRAM (Transcripción de Audio) ---
# Obtén tu clave en: https://console.deepgram.com → API Keys
DEEPGRAM_API_KEY=tu-deepgram-api-key-aqui

# --- IDENTIFICADOR DE USUARIO ---
# UUID de tu usuario en Supabase Auth (para desarrollo/testing).
# Encuéntralo en: Supabase Dashboard → Authentication → Users
USER_ID=tu-uuid-de-usuario-aqui

# --- CONFIGURACIÓN DE API (Opcional) ---
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*

# --- MODELOS (Opcional, ya tienen valores por defecto) ---
# LLM_MODEL_NAME=gemini-2.5-flash-lite
# EMBEDDING_MODEL_NAME=gemini-embedding-001
